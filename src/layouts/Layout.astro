---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Partnership Schools — Coming to Toledo",
  description = "Sign up to learn more about Partnership Schools and our plans for Toledo.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index,follow" />
    <link rel="icon" type="image/png" href="https://thepartnershipschools.org/wp-content/uploads/2022/09/cropped-ps-favicon-32x32.png" />
    <link rel="apple-touch-icon" href="https://thepartnershipschools.org/wp-content/uploads/2022/09/cropped-ps-favicon-180x180.png" />
    <title>{title}</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Figtree:wght@400;500;600;700&family=Zilla+Slab:wght@400;500;600&display=swap"
    />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
  </head>
  <body class="min-h-screen bg-white text-ink">
    <slot />
  </body>
</html>
