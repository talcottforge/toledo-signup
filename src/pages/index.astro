---
import fs from "node:fs";
import path from "node:path";
import Layout from "../layouts/Layout.astro";

const FALLBACK_HERO =
  "https://thepartnershipschools.org/wp-content/uploads/2022/07/PS_Portal_Girls.webp";
const HERO_CANDIDATES = ["hero.jpg", "hero.jpeg", "hero.png", "hero.webp"];
const localHero = HERO_CANDIDATES.find((f) => fs.existsSync(path.resolve("public", f)));
const heroSrc = localHero ? `/${localHero}` : FALLBACK_HERO;
---

<Layout>
  <main class="relative min-h-dvh bg-brand">
    <!-- Top brand band with the Partnership Schools logo -->
    <header class="flex justify-center bg-brand px-5 pt-6 pb-4 sm:pt-8 sm:pb-6">
      <img
        src="https://thepartnershipschools.org/wp-content/uploads/2022/07/PS_logo_white.svg"
        alt="Partnership Schools"
        class="h-10 w-auto sm:h-12"
        width="200"
        height="48"
      />
    </header>

    <!-- Hero + form section: image fills width at natural aspect so "Always,
         we begin again." is always visible, and the form card floats on top
         of the lower portion of the image. -->
    <section class="relative bg-brand">
      <img
        src={heroSrc}
        alt=""
        class="block h-auto w-full"
        loading="eager"
        fetchpriority="high"
      />

      <!-- Form card overlaps the bottom of the image and extends into the
           brand-colored footer band below. -->
      <div class="relative z-10 -mt-20 px-5 pb-12 sm:-mt-28 sm:px-8 sm:pb-16 md:-mt-36">
        <div class="mx-auto w-full max-w-xl rounded-2xl bg-white p-5 shadow-2xl shadow-black/40 ring-1 ring-black/10 sm:max-w-2xl sm:p-8">
          <h2 class="font-display text-[1.125rem] leading-[1.2] text-brand text-balance sm:text-[1.375rem] md:text-[1.5rem]">
            Sign up to learn more about Partnership&nbsp;Schools
          </h2>
          <p class="mt-2 font-serif text-sm text-ink-soft sm:text-base">
            We'll send you updates on our plans for Toledo.
          </p>

          <form
            id="signup-form"
            method="POST"
            action="/api/signup"
            class="mt-5 space-y-4 sm:mt-6 sm:space-y-5"
            novalidate
          >
            <!-- Honeypot -->
            <div class="hidden" aria-hidden="true">
              <label>Website<input type="text" name="website" tabindex="-1" autocomplete="off" /></label>
            </div>

            <div>
              <label for="name" class="block font-display text-sm font-medium text-ink">
                Full name <span class="text-brand">*</span>
              </label>
              <input
                id="name"
                name="name"
                type="text"
                required
                autocomplete="name"
                class="mt-1.5 block w-full rounded-lg border border-black/15 bg-white px-4 py-3 font-sans text-base text-ink placeholder-black/40 focus:border-brand focus:outline-none focus:ring-2 focus:ring-brand/30"
                placeholder="Jane Doe"
              />
            </div>

            <div>
              <label for="email" class="block font-display text-sm font-medium text-ink">
                Email <span class="text-brand">*</span>
              </label>
              <input
                id="email"
                name="email"
                type="email"
                required
                inputmode="email"
                autocomplete="email"
                class="mt-1.5 block w-full rounded-lg border border-black/15 bg-white px-4 py-3 font-sans text-base text-ink placeholder-black/40 focus:border-brand focus:outline-none focus:ring-2 focus:ring-brand/30"
                placeholder="jane@example.com"
              />
            </div>

            <div>
              <label for="organization" class="block font-display text-sm font-medium text-ink">
                Company / organization <span class="font-sans text-xs font-normal text-ink-soft">(optional)</span>
              </label>
              <input
                id="organization"
                name="organization"
                type="text"
                autocomplete="organization"
                class="mt-1.5 block w-full rounded-lg border border-black/15 bg-white px-4 py-3 font-sans text-base text-ink placeholder-black/40 focus:border-brand focus:outline-none focus:ring-2 focus:ring-brand/30"
                placeholder="Acme Co."
              />
            </div>

            <button
              type="submit"
              id="submit-btn"
              class="group relative w-full overflow-hidden rounded-full bg-brand px-6 py-4 text-center font-display text-sm font-semibold uppercase tracking-wide text-white transition hover:bg-brand-dark focus:outline-none focus:ring-4 focus:ring-brand/30 disabled:cursor-not-allowed disabled:opacity-60 sm:text-base"
            >
              <span id="submit-label">Sign up to learn more</span>
            </button>

            <p id="form-error" class="hidden font-sans text-sm text-brand" role="alert"></p>
          </form>
        </div>
      </div>
    </section>

    <!-- Bottom brand band -->
    <footer class="bg-brand px-5 pb-6 pt-2 text-center font-sans text-xs text-white/80 sm:pb-8">
      &copy; {new Date().getFullYear()} Partnership Schools
    </footer>
  </main>
</Layout>

<script is:inline>
  const form = document.getElementById("signup-form");
  const btn = document.getElementById("submit-btn");
  const label = document.getElementById("submit-label");
  const errEl = document.getElementById("form-error");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    errEl.classList.add("hidden");
    errEl.textContent = "";
    btn.disabled = true;
    const originalText = label.textContent;
    label.textContent = "Submitting…";

    try {
      const fd = new FormData(form);
      const res = await fetch("/api/signup", {
        method: "POST",
        body: fd,
        headers: { Accept: "application/json" },
      });
      if (res.ok) {
        window.location.href = "/thank-you";
        return;
      }
      const data = await res.json().catch(() => ({}));
      throw new Error(data.error || "Something went wrong. Please try again.");
    } catch (err) {
      errEl.textContent = err.message || "Unable to submit. Please try again.";
      errEl.classList.remove("hidden");
      btn.disabled = false;
      label.textContent = originalText;
    }
  });
</script>
