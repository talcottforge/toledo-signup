---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <main class="relative min-h-screen">
    <!-- Hero / signup -->
    <section class="relative overflow-hidden">
      <!-- Background image: reuse Partnership Schools collateral -->
      <div class="absolute inset-0 -z-10">
        <img
          src="https://thepartnershipschools.org/wp-content/uploads/2022/07/PS_Portal_Girls.webp"
          alt=""
          class="h-full w-full object-cover object-center"
          loading="eager"
          fetchpriority="high"
        />
        <div class="absolute inset-0 bg-gradient-to-b from-brand/85 via-brand/75 to-brand/95"></div>
      </div>

      <div class="mx-auto flex min-h-screen max-w-2xl flex-col justify-between px-6 py-10 sm:px-8 sm:py-14">
        <!-- Logo -->
        <header class="flex items-center">
          <img
            src="https://thepartnershipschools.org/wp-content/uploads/2022/07/PS_logo_white.svg"
            alt="Partnership Schools"
            class="h-10 w-auto sm:h-12"
            width="200"
            height="48"
          />
        </header>

        <!-- Content card -->
        <div class="my-10 sm:my-14">
          <p class="font-display text-sm uppercase tracking-[0.25em] text-white/80">
            Coming to Toledo
          </p>
          <h1 class="mt-4 font-display text-4xl leading-[1.1] text-white sm:text-5xl md:text-6xl">
            Stronger schools.<br />
            <span class="text-white/90">Stronger community.</span>
          </h1>
          <p class="mt-6 max-w-xl font-serif text-lg text-white/90 sm:text-xl">
            For more than thirty years, Partnership Schools has helped urban Catholic schools deliver an excellent, character-shaping education. Now we're planning something new for Toledo.
          </p>

          <!-- Form card -->
          <div class="mt-10 rounded-2xl bg-white p-6 shadow-2xl shadow-black/20 ring-1 ring-black/5 sm:p-8">
            <h2 class="font-display text-2xl text-brand sm:text-3xl">
              Sign up to learn more about Partnership Schools
            </h2>
            <p class="mt-2 font-serif text-ink-soft">
              We'll send you updates on our plans for Toledo.
            </p>

            <form
              id="signup-form"
              method="POST"
              action="/api/signup"
              class="mt-6 space-y-5"
              novalidate
            >
              <!-- Honeypot -->
              <div class="hidden" aria-hidden="true">
                <label>Website<input type="text" name="website" tabindex="-1" autocomplete="off" /></label>
              </div>

              <div>
                <label for="name" class="block font-display text-sm font-medium text-ink">
                  Full name <span class="text-brand">*</span>
                </label>
                <input
                  id="name"
                  name="name"
                  type="text"
                  required
                  autocomplete="name"
                  class="mt-1.5 block w-full rounded-lg border border-black/15 bg-white px-4 py-3 font-sans text-base text-ink placeholder-black/40 focus:border-brand focus:outline-none focus:ring-2 focus:ring-brand/30"
                  placeholder="Jane Doe"
                />
              </div>

              <div>
                <label for="email" class="block font-display text-sm font-medium text-ink">
                  Email <span class="text-brand">*</span>
                </label>
                <input
                  id="email"
                  name="email"
                  type="email"
                  required
                  autocomplete="email"
                  class="mt-1.5 block w-full rounded-lg border border-black/15 bg-white px-4 py-3 font-sans text-base text-ink placeholder-black/40 focus:border-brand focus:outline-none focus:ring-2 focus:ring-brand/30"
                  placeholder="jane@example.com"
                />
              </div>

              <div>
                <label for="organization" class="block font-display text-sm font-medium text-ink">
                  Company / organization <span class="font-sans text-xs font-normal text-ink-soft">(optional)</span>
                </label>
                <input
                  id="organization"
                  name="organization"
                  type="text"
                  autocomplete="organization"
                  class="mt-1.5 block w-full rounded-lg border border-black/15 bg-white px-4 py-3 font-sans text-base text-ink placeholder-black/40 focus:border-brand focus:outline-none focus:ring-2 focus:ring-brand/30"
                  placeholder="Acme Co."
                />
              </div>

              <button
                type="submit"
                id="submit-btn"
                class="group relative w-full overflow-hidden rounded-full bg-brand px-8 py-4 text-center font-display text-base font-semibold uppercase tracking-wide text-white transition hover:bg-brand-dark focus:outline-none focus:ring-4 focus:ring-brand/30 disabled:cursor-not-allowed disabled:opacity-60"
              >
                <span id="submit-label">Sign up to learn more</span>
              </button>

              <p id="form-error" class="hidden font-sans text-sm text-brand"></p>
            </form>
          </div>
        </div>

        <footer class="mt-auto pt-6 font-sans text-xs text-white/70">
          &copy; {new Date().getFullYear()} Partnership Schools &middot; CCMT Spring Gala
        </footer>
      </div>
    </section>
  </main>
</Layout>

<script is:inline>
  const form = document.getElementById("signup-form");
  const btn = document.getElementById("submit-btn");
  const label = document.getElementById("submit-label");
  const errEl = document.getElementById("form-error");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    errEl.classList.add("hidden");
    errEl.textContent = "";
    btn.disabled = true;
    const originalText = label.textContent;
    label.textContent = "Submitting…";

    try {
      const fd = new FormData(form);
      const res = await fetch("/api/signup", {
        method: "POST",
        body: fd,
        headers: { Accept: "application/json" },
      });
      if (res.ok) {
        window.location.href = "/thank-you";
        return;
      }
      const data = await res.json().catch(() => ({}));
      throw new Error(data.error || "Something went wrong. Please try again.");
    } catch (err) {
      errEl.textContent = err.message || "Unable to submit. Please try again.";
      errEl.classList.remove("hidden");
      btn.disabled = false;
      label.textContent = originalText;
    }
  });
</script>
