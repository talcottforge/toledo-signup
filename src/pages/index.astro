---
import fs from "node:fs";
import path from "node:path";
import Layout from "../layouts/Layout.astro";

const FALLBACK_HERO =
  "https://thepartnershipschools.org/wp-content/uploads/2022/07/PS_Portal_Girls.webp";
const HERO_CANDIDATES = ["hero.jpg", "hero.jpeg", "hero.png", "hero.webp"];
const localHero = HERO_CANDIDATES.find((f) => fs.existsSync(path.resolve("public", f)));
const heroSrc = localHero ? `/${localHero}` : FALLBACK_HERO;
---

<Layout>
  <main class="relative min-h-dvh bg-brand">
    <!-- Top brand band with the Partnership Schools logo (minimal cushion) -->
    <header class="flex justify-center bg-brand px-5 py-3 sm:py-4">
      <img
        src="https://thepartnershipschools.org/wp-content/uploads/2022/07/PS_logo_white.svg"
        alt="Partnership Schools"
        class="h-10 w-auto sm:h-12"
        width="200"
        height="48"
      />
    </header>

    <!-- Hero section.
         Mobile (<md): image shows as a natural-aspect banner at the top so
           "Always, we begin again." is fully readable. A maroon overlay
           blends the image into the surrounding brand-colored bands.
         Desktop (md+): image becomes a full-viewport background (object-cover,
           anchored to the top so the text never crops) with a darker overlay
           and the signup card floating centered in front. -->
    <section class="relative bg-brand lg:flex lg:min-h-[88vh] lg:items-end lg:justify-center lg:px-8 lg:pb-16 lg:pt-24">
      <!-- Narrow viewports (<lg): image shows as a banner at its natural
           aspect so the full text fits -->
      <div class="relative lg:hidden">
        <img
          src={heroSrc}
          alt=""
          class="block h-auto w-full"
          loading="eager"
          fetchpriority="high"
        />
        <!-- Darken / blend into the maroon bands -->
        <div class="pointer-events-none absolute inset-0 bg-brand/35 mix-blend-multiply"></div>
        <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-brand/20 via-transparent to-brand"></div>
      </div>

      <!-- Wide viewports (lg+): full-viewport background image -->
      <div class="pointer-events-none absolute inset-0 -z-0 hidden lg:block">
        <img
          src={heroSrc}
          alt=""
          class="h-full w-full object-cover object-top"
          loading="eager"
          fetchpriority="high"
        />
        <div class="absolute inset-0 bg-black/55"></div>
        <div class="absolute inset-0 bg-gradient-to-b from-brand/40 via-brand/20 to-brand/70"></div>
      </div>

      <!-- Form card.
           <lg: overlaps the bottom of the banner image via negative margin —
             tuned so the children's faces stay visible above the card.
           lg+: sits in the lower portion of the hero on top of the bg image. -->
      <div class="relative z-10 -mt-16 px-5 pb-8 sm:-mt-24 sm:px-8 sm:pb-10 lg:mt-0 lg:w-full lg:max-w-2xl lg:px-0 lg:pb-0">
        <div class="mx-auto w-full max-w-xl rounded-2xl bg-white p-5 shadow-2xl shadow-black/40 ring-1 ring-black/10 sm:max-w-2xl sm:p-7">
          <h2 class="font-display text-[1.125rem] leading-[1.2] text-brand text-balance sm:text-[1.375rem] md:text-[1.5rem]">
            Sign up to learn more about Partnership&nbsp;Schools
          </h2>

          <form
            id="signup-form"
            method="POST"
            action="/api/signup"
            class="mt-4 space-y-3.5 sm:space-y-4"
            novalidate
          >
            <!-- Honeypot -->
            <div class="hidden" aria-hidden="true">
              <label>Website<input type="text" name="website" tabindex="-1" autocomplete="off" /></label>
            </div>

            <div>
              <label for="name" class="block font-display text-sm font-medium text-ink">
                Full name <span class="text-brand">*</span>
              </label>
              <input
                id="name"
                name="name"
                type="text"
                required
                autocomplete="name"
                class="mt-1.5 block w-full rounded-lg border border-black/15 bg-white px-4 py-3 font-sans text-base text-ink placeholder-black/40 focus:border-brand focus:outline-none focus:ring-2 focus:ring-brand/30"
                placeholder="Jane Doe"
              />
            </div>

            <div>
              <label for="email" class="block font-display text-sm font-medium text-ink">
                Email <span class="text-brand">*</span>
              </label>
              <input
                id="email"
                name="email"
                type="email"
                required
                inputmode="email"
                autocomplete="email"
                class="mt-1.5 block w-full rounded-lg border border-black/15 bg-white px-4 py-3 font-sans text-base text-ink placeholder-black/40 focus:border-brand focus:outline-none focus:ring-2 focus:ring-brand/30"
                placeholder="jane@example.com"
              />
            </div>

            <div>
              <label for="organization" class="block font-display text-sm font-medium text-ink">
                Company / organization <span class="font-sans text-xs font-normal text-ink-soft">(optional)</span>
              </label>
              <input
                id="organization"
                name="organization"
                type="text"
                autocomplete="organization"
                class="mt-1.5 block w-full rounded-lg border border-black/15 bg-white px-4 py-3 font-sans text-base text-ink placeholder-black/40 focus:border-brand focus:outline-none focus:ring-2 focus:ring-brand/30"
                placeholder="Acme Co."
              />
            </div>

            <button
              type="submit"
              id="submit-btn"
              class="group relative w-full overflow-hidden rounded-full bg-brand px-6 py-4 text-center font-display text-sm font-semibold uppercase tracking-wide text-white transition hover:bg-brand-dark focus:outline-none focus:ring-4 focus:ring-brand/30 disabled:cursor-not-allowed disabled:opacity-60 sm:text-base"
            >
              <span id="submit-label">Sign up to learn more</span>
            </button>

            <p id="form-error" class="hidden font-sans text-sm text-brand" role="alert"></p>
          </form>
        </div>
      </div>
    </section>

    <!-- Bottom brand band (matches header padding) -->
    <footer class="bg-brand px-5 py-3 text-center font-sans text-xs text-white/80 sm:py-4">
      &copy; {new Date().getFullYear()} Partnership Schools
    </footer>
  </main>
</Layout>

<script is:inline>
  const form = document.getElementById("signup-form");
  const btn = document.getElementById("submit-btn");
  const label = document.getElementById("submit-label");
  const errEl = document.getElementById("form-error");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    errEl.classList.add("hidden");
    errEl.textContent = "";
    btn.disabled = true;
    const originalText = label.textContent;
    label.textContent = "Submitting…";

    try {
      const fd = new FormData(form);
      const res = await fetch("/api/signup", {
        method: "POST",
        body: fd,
        headers: { Accept: "application/json" },
      });
      if (res.ok) {
        window.location.href = "/thank-you";
        return;
      }
      const data = await res.json().catch(() => ({}));
      throw new Error(data.error || "Something went wrong. Please try again.");
    } catch (err) {
      errEl.textContent = err.message || "Unable to submit. Please try again.";
      errEl.classList.remove("hidden");
      btn.disabled = false;
      label.textContent = originalText;
    }
  });
</script>
