---
import fs from "node:fs";
import path from "node:path";
import Layout from "../layouts/Layout.astro";

const FALLBACK_HERO =
  "https://thepartnershipschools.org/wp-content/uploads/2022/07/PS_Portal_Girl2.webp";
const HERO_CANDIDATES = ["hero.jpg", "hero.jpeg", "hero.png", "hero.webp"];
const localHero = HERO_CANDIDATES.find((f) => fs.existsSync(path.resolve("public", f)));
const heroSrc = localHero ? `/${localHero}` : FALLBACK_HERO;
---

<Layout title="Thank you — Partnership Schools" description="Thanks for signing up to learn more about Partnership Schools.">
  <main class="relative min-h-dvh bg-brand">
    <header class="flex justify-center bg-brand px-5 py-3 sm:py-4">
      <img
        src="https://thepartnershipschools.org/wp-content/uploads/2022/07/PS_logo_white.svg"
        alt="Partnership Schools"
        class="h-10 w-auto sm:h-12"
        width="200"
        height="48"
      />
    </header>

    <section class="relative bg-brand lg:flex lg:min-h-[88vh] lg:items-end lg:justify-center lg:px-8 lg:pb-6 lg:pt-24">
      <div class="relative lg:hidden">
        <img
          src={heroSrc}
          alt=""
          class="block h-auto w-full"
          loading="eager"
        />
        <div class="pointer-events-none absolute inset-0 bg-brand/35 mix-blend-multiply"></div>
        <div class="pointer-events-none absolute inset-0 bg-gradient-to-b from-brand/20 via-transparent to-brand"></div>
      </div>

      <div class="pointer-events-none absolute inset-0 -z-0 hidden lg:block">
        <img
          src={heroSrc}
          alt=""
          class="h-full w-full object-cover object-[50%_35%]"
          loading="eager"
        />
        <div class="absolute inset-0 bg-black/55"></div>
        <div class="absolute inset-0 bg-gradient-to-b from-brand/40 via-brand/20 to-brand/70"></div>
      </div>

      <div class="relative z-10 -mt-36 px-5 pb-10 sm:-mt-44 sm:px-8 sm:pb-12 lg:mt-0 lg:w-full lg:max-w-xl lg:px-0 lg:pb-0">
        <div class="mx-auto w-full max-w-xl rounded-2xl bg-white p-6 shadow-2xl shadow-black/40 ring-1 ring-black/10 sm:max-w-2xl sm:p-10">
          <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-brand-soft">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="h-7 w-7 text-brand">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          </div>
          <h1 class="mt-5 text-center font-display text-3xl text-brand sm:text-4xl">
            Thank you for signing up!
          </h1>
          <p class="mt-4 text-center font-serif text-base text-ink sm:text-lg">
            You'll hear from the Partnership Schools team soon with more information and updates on our work in Toledo.
          </p>
          <p class="mt-3 text-center font-serif text-sm text-ink-soft sm:text-base">
            In the meantime, learn more about our network:
          </p>
          <div class="mt-6 flex justify-center">
            <a
              href="https://thepartnershipschools.org/"
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 rounded-full bg-brand px-5 py-2.5 font-display text-sm font-semibold uppercase tracking-wide text-white transition hover:bg-brand-dark"
            >
              Visit our site
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4">
                <line x1="7" y1="17" x2="17" y2="7"></line>
                <polyline points="7 7 17 7 17 17"></polyline>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <footer class="bg-brand px-5 py-3 text-center font-sans text-xs text-white/80 sm:py-4">
      &copy; {new Date().getFullYear()} Partnership Schools
    </footer>
  </main>
</Layout>
